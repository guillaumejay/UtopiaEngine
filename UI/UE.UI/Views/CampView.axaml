<UserControl xmlns="https://github.com/avaloniaui"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:vm="using:UE.UI.ViewModels"
                mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                x:Class="UE.UI.Views.CampView"
                x:DataType="vm:CampViewModel">
    <ScrollViewer>
        <StackPanel Spacing="12" MaxWidth="560" HorizontalAlignment="Center">
            <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold"/>

            <TextBlock Text="{Binding InfoMessage}" TextWrapping="Wrap" FontStyle="Italic"
                       IsVisible="{Binding InfoMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <Border Classes="card">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding SkullsText}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding GodsHandText}"/>
                    <Button Content="Barrer un crâne (3 énergies, +1 jour)" Command="{Binding UseGodsHandCommand}"
                            IsVisible="{Binding CanUseGodsHand}"/>
                    <TextBlock Text="{Binding BasketText}"/>
                </StackPanel>
            </Border>

            <Border Classes="card" IsVisible="{Binding CanRest}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Repos : 1 PV récupéré par jour passé." TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <NumericUpDown Minimum="1" Maximum="10" Value="{Binding RestDays, Mode=TwoWay}" Width="120"/>
                        <Button Content="Se reposer" Command="{Binding RestCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="6">
                    <TextBlock Text="Composants" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ComponentsText}"/>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="6">
                    <TextBlock Text="Objets" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ItemsText}"/>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="6">
                    <TextBlock Text="Trésors légendaires" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TreasuresText}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Button Content="Retour aux régions" Command="{Binding BackCommand}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
