<UserControl xmlns="https://github.com/avaloniaui"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:vm="using:UE.UI.ViewModels"
                mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                x:Class="UE.UI.Views.FinalActivationView"
                x:DataType="vm:FinalActivationViewModel">
    <ScrollViewer>
        <StackPanel Spacing="12" MaxWidth="560" HorizontalAlignment="Center">
            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="{Binding DifficultyText}" FontSize="16" FontWeight="Bold"/>

            <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding CanSpendHp}">
                <NumericUpDown Minimum="1" Maximum="{Binding MaxHpToSpend}"
                               Value="{Binding HpToSpend, Mode=TwoWay}" Width="120"/>
                <Button Content="Sacrifier des PV (−1 difficulté par PV)" Command="{Binding SpendHpCommand}"/>
            </StackPanel>

            <TextBlock Text="{Binding Log}" TextWrapping="Wrap" LineHeight="22"/>

            <Button Content="Tenter l'activation (2d6)" Command="{Binding RollCommand}"
                    IsVisible="{Binding IsRolling}" FontSize="16" Padding="16,8"/>

            <StackPanel Spacing="8" IsVisible="{Binding IsFinished}">
                <TextBlock Text="{Binding OutcomeText}" TextWrapping="Wrap" FontSize="18" FontWeight="Bold"/>
                <Button Content="Nouvelle partie" Command="{Binding NewGameCommand}"/>
            </StackPanel>

            <Button Content="Retour aux liens" Command="{Binding BackCommand}"
                    IsVisible="{Binding IsRolling}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
