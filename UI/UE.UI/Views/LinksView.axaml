<UserControl xmlns="https://github.com/avaloniaui"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:vm="using:UE.UI.ViewModels"
                xmlns:loc="using:UE.UI.Localization"
                mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                x:Class="UE.UI.Views.LinksView"
                x:DataType="vm:LinksViewModel">
    <ScrollViewer>
        <StackPanel Spacing="12" MaxWidth="560" HorizontalAlignment="Center">
            <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="{Binding Summary}" FontStyle="Italic" TextWrapping="Wrap"/>
            <ItemsControl ItemsSource="{Binding Links}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:LinkItemViewModel">
                        <Border Classes="card">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Status}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="{x:Static loc:L.ConnectAction}" Command="{Binding ConnectCommand}"
                                        IsVisible="{Binding CanConnect}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="{x:Static loc:L.FinalActivationButton}" Command="{Binding FinalActivationCommand}"
                    IsVisible="{Binding CanFinalActivate}" FontSize="16" Padding="16,8"/>
            <Button Content="{x:Static loc:L.BackToRegions}" Command="{Binding BackCommand}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
