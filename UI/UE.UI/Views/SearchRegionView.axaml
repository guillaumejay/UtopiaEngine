<UserControl xmlns="https://github.com/avaloniaui"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:vm="using:UE.UI.ViewModels"
                xmlns:views="using:UE.UI.Views"
                mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                x:Class="UE.UI.Views.SearchRegionView"
                x:DataType="vm:SearchRegionViewModel">
    <ScrollViewer>
        <StackPanel Spacing="12" MaxWidth="480" HorizontalAlignment="Center">
            <TextBlock Text="{Binding RegionName}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>

            <TextBlock Text="{Binding InfoMessage}" TextWrapping="Wrap" FontStyle="Italic"
                       IsVisible="{Binding InfoMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <ItemsControl ItemsSource="{Binding Cells}" ItemTemplate="{StaticResource DiceCellTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <StackPanel IsVisible="{Binding IsPlacing}">
                <views:DicePairView DataContext="{Binding Dice}"/>
            </StackPanel>

            <StackPanel Spacing="8" IsVisible="{Binding IsBoxFull}">
                <TextBlock Text="{Binding ResultText}" FontSize="16" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding CanUseDowsingRod}">
                    <NumericUpDown Minimum="1" Maximum="100" Value="{Binding DowsingRodNumber, Mode=TwoWay}"
                                   Width="130"/>
                    <Button Content="Utiliser la baguette de sourcier" Command="{Binding UseDowsingRodCommand}"/>
                </StackPanel>
                <Button Content="Appliquer la fouille" Command="{Binding ApplySearchCommand}"/>
            </StackPanel>

            <StackPanel Spacing="8" IsVisible="{Binding IsCombat}">
                <TextBlock Text="{Binding CombatLog}" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding CanRollCombat}">
                    <Button Content="Lancer les dés de combat" Command="{Binding RollCombatCommand}"/>
                    <Button Content="Fuir" Command="{Binding FleeCommand}" IsVisible="{Binding CanFlee}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowWandChoice}">
                    <Button Content="Baguette de paralysie (+2)" Command="{Binding UseWandCommand}"/>
                    <Button Content="Continuer sans baguette" Command="{Binding SkipWandCommand}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Spacing="8" IsVisible="{Binding IsDone}">
                <TextBlock Text="{Binding OutcomeText}" TextWrapping="Wrap" FontSize="16"/>
                <Button Content="Fouiller à nouveau" Command="{Binding ContinueCommand}"
                        IsVisible="{Binding CanContinue}"/>
            </StackPanel>

            <Button Content="Retour aux régions" Command="{Binding BackCommand}"
                    IsVisible="{Binding !IsCombat}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
